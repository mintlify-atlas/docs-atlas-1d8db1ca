  "keyFeatures": [
    "Unified RestClient for all Gate.com trading products (Spot, Margin, Futures, Options, CrossEx, Alpha, OTC)",
    "Full TypeScript support with strongly-typed requests and responses",
    "Robust WebSocket client with automatic reconnection and heartbeat management",
    "Promise-driven WebSocket API client (REST-like interface over WebSocket)",
    "Event-driven WebSocket API via sendWSAPIRequest",
    "Automatic authentication for private REST and WebSocket calls",
    "Proxy support via axios integration",
    "Browser/frontend support via webpack bundle",
    "Bundled llms.txt for LLM-assisted development",
    "Automated end-to-end tests with real API calls"
  ],
